{
  "name": "@vanyauhalin/eslint-config",
  "version": "0.0.0",
  "private": true,
  "description": "ESLint config by @vanyauhalin",
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "repository": "github:vanyauhalin/eslint-config",
  "license": "MIT",
  "author": "Ivan Uhalin <vanyauhalin@gmail.com>",
  "type": "module",
  "workspaces": [
    "packages"
  ],
  "scripts": {
    "build": "node .esbuildrc.js ./packages/eslint-config-${npm_config_package}",
    "build-base": "pnpm build --package=base"
  },
  "devDependencies": {
    "@arkweid/lefthook": "^0.7.7",
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@vanyauhalin/eslint-config-base": "workspace:^",
    "esbuild": "^0.14.38",
    "eslint": "^8.13.0"
  },
  "engines": {
    "node": ">=12",
    "npm": ">=6",
    "pnpm": ">=4"
  }
}
